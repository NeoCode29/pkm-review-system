# =======================================================
# PKM Review — Production Environment Variables
# Salin file ini ke .env, lalu isi semua nilainya
# JANGAN commit file .env ke git!
# =======================================================

# =======================================================
# DATABASE
# =======================================================
POSTGRES_PASSWORD=ganti-dengan-password-kuat-minimal-32-karakter

# =======================================================
# SUPABASE AUTH (JWT)
# Generate JWT_SECRET baru: openssl rand -base64 32
# =======================================================
JWT_SECRET=ganti-dengan-secret-minimal-32-karakter-openssl-rand-base64-32
JWT_EXPIRY=3600

# URL auth Supabase yang dapat diakses publik
API_EXTERNAL_URL=https://auth.yourdomain.com

# URL frontend (untuk redirect setelah login/konfirmasi email)
SITE_URL=https://yourdomain.com
ADDITIONAL_ALLOWED_URIS=

DISABLE_SIGNUP=false
MAILER_AUTOCONFIRM=true

# =======================================================
# SMTP (untuk email verifikasi / reset password)
# =======================================================
SMTP_ADMIN_EMAIL=admin@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_SENDER_NAME=PKM Review

# =======================================================
# SUPABASE API KEYS
# Cara generate:
#   ANON_KEY dan SERVICE_ROLE_KEY adalah JWT yang di-sign pakai JWT_SECRET
#   Gunakan tool: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#   atau jalankan: node -e "const jwt=require('jsonwebtoken'); console.log(jwt.sign({role:'anon',iss:'supabase',iat:1700000000,exp:1900000000},process.env.JWT_SECRET,{algorithm:'HS256'}))"
# =======================================================
ANON_KEY=ganti-dengan-anon-jwt-yang-di-sign-pakai-JWT_SECRET
SERVICE_ROLE_KEY=ganti-dengan-service-role-jwt-yang-di-sign-pakai-JWT_SECRET

# =======================================================
# FRONTEND (Next.js) — URLs publik
# =======================================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_SUPABASE_URL=https://auth.yourdomain.com

# =======================================================
# BACKEND (NestJS)
# =======================================================
CORS_ORIGIN=https://yourdomain.com
